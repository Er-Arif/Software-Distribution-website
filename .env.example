# Shared
APP_ENV=local
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/software_platform
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-long-random-secret-with-at-least-32-characters
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30
PASSWORD_RESET_MINUTES=30

# License signing
SIGNING_KEY_ID=local-dev-key
LICENSE_PRIVATE_KEY_PEM=
LICENSE_PUBLIC_KEY_PEM=

# Storage
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_ASSETS_BUCKET=public-assets
S3_PRIVATE_INSTALLERS_BUCKET=private-installers
S3_UPDATE_PATCHES_BUCKET=update-patches
SIGNED_URL_TTL_SECONDS=300

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Email
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=hello@example.com

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
